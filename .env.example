# ── FaceNet Attendance System – Environment Variables ──
# Copy to .env and fill in your values.
# Never commit .env to version control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_DEBUG=1

# Database  (set DB_TYPE=sqlite to skip PostgreSQL config)
DB_TYPE=postgres

# PostgreSQL (only used when DB_TYPE=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Yoki143@
POSTGRES_DB=attendance_system

# Face recognition threshold (0.0 – 1.0)
# Lower = more permissive, Higher = stricter
RECOGNITION_THRESHOLD=0.75
