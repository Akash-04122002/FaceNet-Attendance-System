# ── FaceNet Attendance System – Environment Variables ──
# Copy to .env and fill in your values.
# Never commit .env to version control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_DEBUG=1

# Database  (set DB_TYPE=sqlite to skip MySQL config)
DB_TYPE=sqlite

# MySQL (only used when DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=attendance_system

# Face recognition threshold (0.0 – 1.0)
# Lower = more permissive, Higher = stricter
RECOGNITION_THRESHOLD=0.75
